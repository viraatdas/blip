{
  "name": "blip",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:worker": "cd apps/worker && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "build:runner": "bun build runner/blip-runner.ts --target=node --outfile=runner/blip-runner.js",
    "db:migrate": "supabase db push",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@supabase/supabase-js": "^2.49.0",
    "e2b": "^1.2.0",
    "stripe": "^17.0.0",
    "svix": "^1.42.0",
    "zod": "^3.24.0"
  }
}
