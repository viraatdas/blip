{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@blip/shared": ["packages/shared/src"],
      "@blip/shared/*": ["packages/shared/src/*"],
      "@blip/db": ["packages/db/src"],
      "@blip/db/*": ["packages/db/src/*"],
      "@blip/e2b": ["packages/e2b/src"],
      "@blip/e2b/*": ["packages/e2b/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "apps/web", "runner"]
}
